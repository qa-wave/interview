{
  "name": "books-mock",
  "version": "1.1.0",
  "description": "REST and SOAP mock services for a books integration interview.",
  "main": "server/server.js",
  "bin": {
    "books-mock": "./server/server.js"
  },
  "scripts": {
    "start": "node server/server.js",
    "dev": "node server/server.js",
    "test": "node --test test/*.test.js",
    "package": "node scripts/build-packages.js",
    "deploy": "vercel --prod --yes"
  },
  "keywords": [
    "mock",
    "rest",
    "soap",
    "books",
    "interview"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.3"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "6.19.0"
  },
  "pkg": {
    "assets": [
      "server/mocks/**/*.json",
      "server/openapi.yaml",
      "README.md",
      "server/**/*.html",
      "server/docs/**/*.yaml",
      "client/**/*.html",
      "client/**/*.md"
    ],
    "targets": [
      "node24-macos-arm64",
      "node24-macos-x64",
      "node24-win-x64"
    ],
    "outputPath": "dist/bin"
  },
  "engines": {
    "node": ">=24"
  }
}
