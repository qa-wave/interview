{
  "info": {
    "name": "Interview Mock REST and SOAP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4010"
    },
    {
      "key": "bearerToken",
      "value": "eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.CEPS-HUB-INTERVIEW-2026"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}"
      }
    ]
  },
  "item": [
    {
      "name": "REST API",
      "item": [
        {
          "name": "List Interviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rest/interviews"
          }
        },
        {
          "name": "List Interviews (filtered by status)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rest/interviews?status=SCHEDULED"
          }
        },
        {
          "name": "Get Interview",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rest/interviews/INT-001"
          }
        },
        {
          "name": "Create Interview",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidateId\": \"CAND-002\",\n  \"position\": \"Integration Tester\",\n  \"scheduledAt\": \"2026-06-01T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/rest/interviews"
          }
        },
        {
          "name": "Update Interview Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": "{{baseUrl}}/rest/interviews/INT-001/status"
          }
        },
        {
          "name": "Evaluate Interview",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"score\": 72\n}"
            },
            "url": "{{baseUrl}}/rest/interviews/INT-001/evaluate"
          }
        },
        {
          "name": "Get Candidate",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rest/candidates/CAND-001"
          }
        },
        {
          "name": "Search Candidates by Email",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rest/candidates?email=petr.svoboda@example.test"
          }
        }
      ]
    },
    {
      "name": "SOAP API",
